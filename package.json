{
  "name": "teknoloji-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@huggingface/inference": "^4.13.15",
    "@supabase/supabase-js": "^2.93.0",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.17",
    "cors": "^2.8.6",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "express": "^5.2.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder",
    "deploy": "npx wrangler pages deploy dist --project-name=teknoloji-hub"
  },
  "build": {
    "appId": "com.teknoloji.hub",
    "productName": "TeknolojiHub",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "!node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    }
  }
}
